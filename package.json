{
  "name": "project-inventory",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c green,cyan \"python -m uvicorn backend.app.main:app --reload --port 4000\" \"npm run dev --workspace frontend\"",
    "dev:backend": "python -m uvicorn backend.app.main:app --reload --port 4000",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "lint": "npm run lint --workspace frontend"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "packageManager": "pnpm@10.23.0+sha512.21c4e5698002ade97e4efe8b8b4a89a8de3c85a37919f957e7a0f30f38fbc5bbdd05980ffe29179b2fb6e6e691242e098d945d1601772cad0fef5fb6411e2a4b"
}
